        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true}, "indexByName": {"Namespace": 0, "Pod": 1, "Node": 2, "Pod IP": 3, "Status": 4, "Kind": 5, "Created By": 6}, "renameByName": {"created_by_kind": "Kind", "created_by_name": "Created By", "namespace": "Namespace", "node": "Node", "phase": "Status", "pod": "Pod", "pod_ip": "Pod IP"}}}
